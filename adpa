local ScreenGui = Instance.new("ScreenGui", PlayerGui)
local OpenBtn = Instance.new("TextButton", ScreenGui)
OpenBtn.Size, OpenBtn.Position = UDim2.new(0, 60, 0, 30), UDim2.new(0, 10, 0, 10)
OpenBtn.Text = "MENU"
OpenBtn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
OpenBtn.TextColor3 = Color3.new(1, 1, 1)

local MainFrame = Instance.new("Frame", ScreenGui)
MainFrame.Size, MainFrame.Position = UDim2.new(0, 200, 0, 300), UDim2.new(0.05, 0, 0.3, 0)
MainFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
MainFrame.Active, MainFrame.Draggable = true, true
MainFrame.Visible = false
Instance.new("UICorner", MainFrame)

OpenBtn.MouseButton1Click:Connect(function() MainFrame.Visible = not MainFrame.Visible end)

local function createButton(name, yPos)
    local btn = Instance.new("TextButton", MainFrame)
    btn.Size, btn.Position = UDim2.new(0.8, 0, 0, 35), UDim2.new(0.1, 0, 0, yPos)
    btn.Text = "[ OFF ] " .. name
    btn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    btn.TextColor3 = Color3.new(1, 1, 1)
    Instance.new("UICorner", btn)
    
    btn.MouseButton1Click:Connect(function()
        Settings[name] = not Settings[name]
        btn.Text = (Settings[name] and "[ ON ] " or "[ OFF ] ") .. name
        btn.BackgroundColor3 = Settings[name] and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(50, 50, 50)
    end)
end

createButton("AUTO HARVEST", 60)
createButton("AUTO STEAL", 105)
createButton("AUTO ESP", 150)

