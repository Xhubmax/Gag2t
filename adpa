-- دالة الويبهوك المحدثة (تظهر اسم اللاعب)
local function sendWebhook(action, info)
    local data = {
        ["embeds"] = {{
            ["title"] = "Xwao Logs",
            ["fields"] = {
                {["name"] = "Player", ["value"] = LocalPlayer.Name, ["inline"] = true},
                {["name"] = "Action", ["value"] = action, ["inline"] = true},
                {["name"] = "Target", ["value"] = info, ["inline"] = true}
            },
            ["color"] = 16711680,
            ["footer"] = {["text"] = "Xwao Menu | Security Alert"}
        }}
    }
    pcall(function() 
        request({
            Url = WebhookURL, 
            Method = "POST", 
            Headers = {["Content-Type"] = "application/json"}, 
            Body = HttpService:JSONEncode(data)
        }) 
    end)
end

